# Environment variables for Docker Compose
# Copy this to .env and customize for your environment

# === Database Configuration ===
POSTGRES_DB=aichatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# === MongoDB Configuration ===
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_PORT=27017

# === Redis Configuration ===
REDIS_PASSWORD=redis
REDIS_PORT=6379

# === Kafka Configuration ===
KAFKA_BROKERS=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_PORT=9092

# === Spring Application ===
SPRING_PROFILES_ACTIVE=local
# Flyway migration settings
FLYWAY_ENABLED=false
FLYWAY_OUT_OF_ORDER=false

# === Spring AI / Ollama Configuration ===
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama2:latest

# === Observability ===
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# === Security ===
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=3600000

# === RAG / Vector Database ===
RAG_ENABLED=true
PGVECTOR_ENABLED=true

# === Feature Flags ===
FEATURES_RAG_ENABLED=true
FEATURES_INTENT_CLASSIFICATION=true
FEATURES_RECOMMENDATIONS=true
FEATURES_SENTIMENT_ANALYSIS=true
FEATURES_ESCALATION_AUTOMATION=true
FEATURES_MULTILINGUAL_SUPPORT=false
FEATURES_KB_AUTO_INDEXING=true

# === Service Ports ===
BACKEND_PORT=8080
FRONTEND_PORT=4200
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
POSTGRES_PORT=5432
MONGO_PORT=27017
REDIS_PORT=6379
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181
