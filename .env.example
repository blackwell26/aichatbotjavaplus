# Environment variables for Docker Compose
# Copy this to .env and customize for your environment

# === Database Configuration ===
POSTGRES_DB=aichatbot
POSTGRES_USER=aichatbot
POSTGRES_PASSWORD=aichatbot
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
POSTGRES_INIT_SCHEMA=public

# === MongoDB Configuration ===
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DB=aichatbot
MONGO_PORT=27017

# === Redis Configuration ===
REDIS_PASSWORD=redis
REDIS_PORT=6379

# === Kafka Configuration ===
KAFKA_BROKERS=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_PORT=9092
KAFKA_UI_PORT=8088

# === RabbitMQ (optional profile) ===
RABBITMQ_ENABLED=false
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# === Spring Application ===
SPRING_PROFILES_ACTIVE=docker
# Flyway migration settings
FLYWAY_ENABLED=false
FLYWAY_OUT_OF_ORDER=false

# === Spring AI / Ollama Configuration ===
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
OLLAMA_PORT=11434

# === Observability ===
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# === Grafana ===
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# === OpenSearch / Tracing ===
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_TRANSPORT_PORT=9300
OPENSEARCH_DASHBOARDS_PORT=5601
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# === Security ===
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=3600000

# === RAG / Vector Database ===
RAG_ENABLED=true
PGVECTOR_ENABLED=true

# === Feature Flags ===
FEATURES_RAG_ENABLED=true
FEATURES_INTENT_CLASSIFICATION=true
FEATURES_RECOMMENDATIONS=true
FEATURES_SENTIMENT_ANALYSIS=true
FEATURES_ESCALATION_AUTOMATION=true
FEATURES_MULTILINGUAL_SUPPORT=false
FEATURES_KB_AUTO_INDEXING=true

# === Service Ports ===
BACKEND_PORT=8080
FRONTEND_PORT=4200
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
POSTGRES_PORT=5432
MONGO_PORT=27017
REDIS_PORT=6379
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
JAEGER_UI_PORT=16686
